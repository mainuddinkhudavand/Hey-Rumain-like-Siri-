# ============================================================
#  Rumain 3D Desktop Assistant — Environment Configuration
# ============================================================

# ── Wake Word Detection ──────────────────────────────────────
# Options: "pyaudio_threshold" (default) or "vosk" (fully offline)
WAKE_WORD_ENGINE=pyaudio_threshold
WAKE_WORD=hey rumain
WAKE_WORD_SENSITIVITY=0.5

# ── Speech-To-Text (STT) ─────────────────────────────────────
# Options: "google" (online free) or "vosk" (local offline)
STT_ENGINE=google

# ── LLM Brain ────────────────────────────────────────────────
# Options: "claude" (API key required) or "ollama" (local offline)
LLM_PROVIDER=claude
CLAUDE_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Ollama fallback settings (if provider is set to 'ollama')
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Text-To-Speech (TTS) ─────────────────────────────────────
# Options: "edge-tts" (online free natural voice) or "pyttsx3" (local offline)
TTS_ENGINE=edge-tts
# Edge-TTS soft female voice names:
# en-US-EmmaMultilingualNeural, en-US-AnaNeural, en-US-JennyNeural, en-US-SoniaNeural
EDGE_TTS_VOICE=en-US-EmmaMultilingualNeural

# Local offline pyttsx3 voice settings (if engine is set to 'pyttsx3')
TTS_RATE=175
TTS_VOLUME=1.0
TTS_VOICE_INDEX=1

# ── Desktop Settings ─────────────────────────────────────────
# Hotkey to toggle assistant (double tap this key)
TOGGLE_HOTKEY=ctrl
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
